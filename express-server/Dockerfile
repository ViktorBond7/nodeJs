# Базовий образ — Node.js 20 на Alpine Linux (мінімальна версія)
FROM node:20-alpine

# Встановлюємо змінну середовища для порту
ENV PORT=3000

# Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# Копіюємо файли залежностей першими — для кешування шарів
COPY package*.json ./

# Встановлюємо залежності всередині контейнера
RUN npm ci

# Копіюємо решту файлів проєкту
COPY . .

# Повідомляємо Docker, що застосунок слухає порт 3000
EXPOSE 3000

# Команда запуску застосунку
ENTRYPOINT ["npx", "tsx", "app.ts"]
